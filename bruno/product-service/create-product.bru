meta {
  name: Create Product
  type: http
  seq: 1
}

post {
  url: {{productServiceUrl}}/v1/products
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Wireless Bluetooth Headphones 5",
    "description": "Premium noise-cancelling wireless headphones with 30-hour battery life",
    "price": 129.99,
    "stockQuantity": 50,
    "status": "ACTIVE",
    "categoryId": "{{sampleCategoryId}}"
  }
}
